CREATE TABLE users (
    user_id INT PRIMARY KEY,
    name VARCHAR(100)
);

CREATE TABLE bookings (
    booking_id INT PRIMARY KEY,
    user_id INT,
    room_number INT,
    booking_date DATE
);

CREATE TABLE items (
    item_id INT PRIMARY KEY,
    item_name VARCHAR(100),
    rate INT
);

CREATE TABLE booking_commercials (
    id INT PRIMARY KEY,
    booking_id INT,
    item_id INT,
    quantity INT
);

