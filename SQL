File 2: SQL/02_Hotel_Queries.sql
-- Last booked room
SELECT room_number
FROM bookings
ORDER BY booking_date DESC
LIMIT 1;

-- Billing in Nov
SELECT b.booking_id, SUM(i.rate * bc.quantity) AS total
FROM bookings b
JOIN booking_commercials bc ON b.booking_id = bc.booking_id
JOIN items i ON bc.item_id = i.item_id
WHERE MONTH(b.booking_date)=11
GROUP BY b.booking_id;

-- Bills > 1000
SELECT b.booking_id, SUM(i.rate * bc.quantity) AS total
FROM bookings b
JOIN booking_commercials bc ON b.booking_id = bc.booking_id
JOIN items i ON bc.item_id = i.item_id
GROUP BY b.booking_id
HAVING total > 1000;

-- Most ordered item
SELECT item_id, SUM(quantity) total
FROM booking_commercials
GROUP BY item_id
ORDER BY total DESC;

-- 2nd highest bill
SELECT * FROM (
  SELECT b.booking_id,
  SUM(i.rate * bc.quantity) total,
  DENSE_RANK() OVER (ORDER BY SUM(i.rate * bc.quantity) DESC) rnk
  FROM bookings b
  JOIN booking_commercials bc ON b.booking_id = bc.booking_id
  JOIN items i ON bc.item_id = i.item_id
  GROUP BY b.booking_id
) t WHERE rnk = 2;  

