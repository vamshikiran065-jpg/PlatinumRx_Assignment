-- Revenue
SELECT sales_channel, SUM(amount)
FROM clinic_sales
GROUP BY sales_channel;

-- Profit
SELECT MONTH(cs.date) month,
SUM(cs.amount) - SUM(e.amount) profit
FROM clinic_sales cs
JOIN expenses e ON MONTH(cs.date)=MONTH(e.date)
GROUP BY month;
